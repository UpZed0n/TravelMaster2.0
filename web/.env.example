# --- 高德 JS API（WebView 内嵌地图）---
# 申请：https://console.amap.com/  Web 端（JS API）Key + 安全密钥
# 勿在此文件填写真实密钥；复制为 .env.local 后填写，或仅在 App「设置」中填写
NEXT_PUBLIC_AMAP_KEY=
NEXT_PUBLIC_AMAP_SECURITY_CODE=

# --- 可选：OpenAI 兼容端点 ---
# 默认在应用内设置中已填通义千问兼容地址；若需覆盖可在此声明
# NEXT_PUBLIC_DEFAULT_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
